# Discord Bot Token
DISCORD_BOT_TOKEN=""

# Torbox API Keys
# You can configure multiple API keys separated by commas for automatic fallback
# when one reaches the active downloads limit

# Option 1: Single API key
TORBOX_API_KEY="your_key_here"

# Option 2: Multiple API keys (automatic fallback)
# TORBOX_API_KEY="key1,key2,key3"

# Example with multiple keys:
# TORBOX_API_KEY="SwU2663pNaq97uSPKTyciSmf8aoSOUwn,VYXZuvOl5S0CcVnvVfjrz1LlNSaP2eEt"

# Note: If an API key reaches the download limit, the bot will automatically
# try to use the next available key in the list.

# Cache Only Mode
# If set to true:
#   - Torrents will only be added if they are already cached in Torbox
#   - Web downloads will be disabled
# If a torrent is not cached, you'll receive a notification instead of starting a new download
CACHE_ONLY=false