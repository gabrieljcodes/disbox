# Discord Bot Token
DISCORD_BOT_TOKEN=""

# Discord OAuth2 (for Web Dashboard)
# Get these from: https://discord.com/developers/applications → Your App → OAuth2
# Add redirect URL: {PROXY_BASE_URL}/auth/callback (e.g. http://localhost:8080/auth/callback)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Torbox API Keys
# You can configure multiple API keys separated by commas for automatic fallback
# when one reaches the active downloads limit

# Option 1: Single API key
TORBOX_API_KEY="your_key_here"

# Option 2: Multiple API keys (automatic fallback)
# TORBOX_API_KEY="key1,key2,key3"

# Example with multiple keys:
# TORBOX_API_KEY="SwU2663pNaq97uSPKTyciSmf8aoSOUwn,VYXZuvOl5S0CcVnvVfjrz1LlNSaP2eEt"

# Note: If an API key reaches the download limit, the bot will automatically
# try to use the next available key in the list.

# Cache Only Mode
# If set to true:
#   - Torrents will only be added if they are already cached in Torbox
#   - Web downloads will be disabled
# If a torrent is not cached, you'll receive a notification instead of starting a new download
CACHE_ONLY=false

# Admin Users
# Comma-separated list of Discord User IDs that will have access to the Admin Panel in the web dashboard
ADMIN_USERS="your_discord_id_here"

# Proxy Server Configuration
# The port the proxy/dashboard server listens on (default: 8080)
# PROXY_PORT=8080

# The public base URL used for generating download links and OAuth2 callbacks
# Set this when running behind a reverse proxy or using a custom domain
# PROXY_BASE_URL="https://your-domain.com"